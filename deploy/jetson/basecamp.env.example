# Copy to /mnt/nvme/apps/Basecamp/.env.production on the Jetson.
# Keep this file out of git after filling secrets.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PORT=4302
HOSTNAME=127.0.0.1

BASECAMP_PUBLIC_URL=https://basecamp.ntechr.com
BASECAMP_AUTH_SECRET=
BASECAMP_DATA_DIR=/mnt/nvme/apps/Basecamp/data
BASECAMP_STORAGE_DIR=/mnt/nvme/apps/Basecamp/.basecamp-data
BASECAMP_SERVICE_NAME=basecamp
BASECAMP_DEPLOY_CWD=/mnt/nvme/apps/Basecamp

# Generate these on the Jetson with:
# openssl rand -hex 32
BASECAMP_CODEX_TOKEN=
# openssl rand -hex 48
# BASECAMP_AUTH_SECRET=

# Optional Google OAuth sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Keep first-run cache workers calm on the shared Jetson.
BASECAMP_GEOCODE_BATCH_SIZE=25
BASECAMP_ICON_BATCH_SIZE=8
BASECAMP_ICON_CONCURRENCY=2
BASECAMP_PUBLIC_BUSINESS_IMPORT_LIMIT=250

# Optional Google-backed startup map. These remain valid build/env defaults, but the
# Admin screen can now save runtime Google Maps settings without rebuilding.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
NEXT_PUBLIC_GOOGLE_MAPS_TECH_MAP_ID=
GOOGLE_MAPS_GEOCODING_API_KEY=

# Optional Axiom SMTP mailbox for profile claim magic links.
BASECAMP_EMAIL_PROVIDER=smtp
BASECAMP_EMAIL_FROM=basecamp@ntechr.com
BASECAMP_EMAIL_FROM_NAME=Basecamp Startup State
BASECAMP_SMTP_HOST=mail.freestonefamily.com
BASECAMP_SMTP_PORT=587
BASECAMP_SMTP_SECURE=false
BASECAMP_SMTP_REQUIRE_TLS=true
BASECAMP_SMTP_TLS_REJECT_UNAUTHORIZED=true
BASECAMP_SMTP_USER=basecamp@ntechr.com
BASECAMP_SMTP_PASS=

# Optional hosted AI providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional Codex path settings. Use a persistent writable home.
CODEX_PATH=codex
CODEX_HOME=/mnt/nvme/apps/Basecamp/.basecamp-data/codex-home
CODEX_RPC_TIMEOUT_MS=45000
CODEX_TURN_TIMEOUT_MS=180000
