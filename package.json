{
  "name": "basecamp",
  "version": "0.1.0",
  "private": true,
  "description": "Basecamp founder navigation and startup map platform for Startup State.",
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build --webpack && node scripts/prepare-standalone.js",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "rm -rf .next/types .next/dev/types && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "env -u NO_COLOR playwright test",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit"
  },
  "dependencies": {
    "@openai/codex": "^0.129.0",
    "csv-parse": "^6.2.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.5",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.1.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.14"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
