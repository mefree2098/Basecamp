# Local defaults work without external services.
BASECAMP_DATA_DIR=./data
BASECAMP_STORAGE_DIR=.basecamp-data

# Optional AI providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional Codex path settings.
CODEX_PATH=codex
CODEX_HOME=.basecamp-data/codex-home
CODEX_RPC_TIMEOUT_MS=45000
CODEX_TURN_TIMEOUT_MS=180000
